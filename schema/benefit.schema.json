{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "benefit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benefit_id",
    "product_id",
    "benefit_name",
    "category",
    "benefit_type",
    "source_id"
  ],
  "properties": {
    "benefit_id": { "type": "string", "minLength": 1 },
    "product_id": { "type": "string", "minLength": 1 },
    "benefit_name": { "type": "string", "minLength": 1 },
    "category": {
      "enum": [
        "카페", "편의점", "외식", "배달", "영화", "구독", "통신", "교통", "택시",
        "대형마트", "주유", "온라인쇼핑", "의료", "도서", "패션", "뷰티", "테마파크",
        "여행", "면세점", "공과금", "쇼핑", "문화", "해외", "간편결제", "기타",
        "교육", "항공", "금융", "렌탈"
      ]
    },
    "merchant_scope_type": { "type": ["string", "null"] },
    "merchants_or_scope": { "type": ["string", "null"] },
    "benefit_type": { "type": "string", "minLength": 1 },
    "benefit_value": { "type": ["number", "null"] },
    "benefit_unit": { "type": ["string", "null"] },
    "min_payment": { "type": ["number", "null"] },
    "per_tx_discount_limit": { "type": ["number", "null"] },
    "monthly_discount_limit": { "type": ["number", "null"] },
    "annual_discount_limit": { "type": ["number", "null"] },
    "limit_group_id": { "type": ["string", "null"] },
    "spend_min": { "type": ["number", "null"] },
    "spend_max": { "type": ["number", "null"] },
    "frequency_period": { "type": ["string", "null"] },
    "frequency_count": { "type": ["number", "null"] },
    "eligible_days": { "type": ["string", "null"] },
    "time_start": { "type": ["string", "null"] },
    "time_end": { "type": ["string", "null"] },
    "payment_channel": { "type": ["string", "null"] },
    "required_funding_method": { "type": ["string", "null"] },
    "requires_coupon": { "type": "boolean" },
    "user_segment": { "type": ["string", "null"] },
    "option_group_id": { "type": ["string", "null"] },
    "option_value": { "type": ["string", "null"] },
    "stackable": { "type": "boolean" },
    "application_order": { "type": ["number", "null"] },
    "start_date": { "type": ["string", "null"] },
    "end_date": { "type": ["string", "null"] },
    "exclusions_summary": { "type": ["string", "null"] },
    "raw_condition_note": { "type": ["string", "null"] },
    "source_id": { "type": "string", "minLength": 1 },
    "confidence": { "enum": ["high", "medium", "low", null] }
  }
}
